# Hytale Panel - Environment Variables
# Copy to /etc/hytale-panel/env on the server (install.sh does this automatically)

# REQUIRED: JWT secret for authentication (generate with: openssl rand -base64 48)
JWT_SECRET=

# REQUIRED: Shared secret for crash-notify script (generate with: openssl rand -hex 32)
CRASH_NOTIFY_TOKEN=

# Panel server settings
PORT=3000
BIND_HOST=127.0.0.1
NODE_ENV=production

# Set to false when running behind plain HTTP (e.g. IP-only setup without TLS).
# Defaults to true when NODE_ENV=production. If true and the panel is served over
# HTTP, browsers will silently refuse to send the session cookie.
SECURE_COOKIE=true

# Gameserver paths
SERVER_DIR=/home/hytale/server
ASSETS_DIR=/home/hytale/HytaleAssets

# Optional: Discord webhook for notifications
DISCORD_WEBHOOK=
